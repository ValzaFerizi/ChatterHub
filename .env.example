# ===========================
# ENVIRONMENT VARIABLES
# Copy this file and rename to .env
# ===========================

# Server
PORT=
NODE_ENV=development

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MongoDB
MONGO_USER=
MONGO_PASSWORD=
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000